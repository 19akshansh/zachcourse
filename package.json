{
  "name": "ZachCourse",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "mcp": "tsx mcp_server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "eval": "tsx scripts/eval-lessons.ts",
    "test": "vitest run",
    "db:setup": "npx prisma generate && npx prisma migrate dev --name init",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.2",
    "@axe-core/react": "^4.12.1",
    "@dagrejs/dagre": "^3.0.0",
    "@hookform/resolvers": "^5.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.19.3",
    "@tailwindcss/vite": "^4.1.14",
    "@trpc/client": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@xyflow/react": "^12.11.1",
    "ai": "^7.0.4",
    "better-auth": "^1.6.22",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "html2canvas": "^1.4.1",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "katex": "^0.17.0",
    "localforage": "^1.10.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hook-form": "^7.80.0",
    "react-i18next": "^17.0.8",
    "react-joyride": "^3.0.2",
    "react-markdown": "^10.1.0",
    "recharts": "^3.9.1",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sonner": "^2.0.7",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pdf-parse": "^1.1.5",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
