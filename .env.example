# Database Connection URL (NeonDB, PostgreSQL)
# For NeonDB specifically: DATABASE_URL should end with ?sslmode=require&pgbouncer=true
DATABASE_URL="postgresql://user:pass@ep-host-name-pooler.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true"

# NeonDB needs both DATABASE_URL for pooled connections and DIRECT_URL for migrations.
# DIRECT_URL is the same connection string but WITHOUT ?pgbouncer=true
DIRECT_URL="postgresql://user:pass@ep-host-name.region.aws.neon.tech/dbname?sslmode=require"

# Better Auth Configuration Secrets & URLs
BETTER_AUTH_SECRET="your_32_character_better_auth_secret_here"
BETTER_AUTH_URL="http://localhost:3000"

# GitHub OAuth App Credentials (for OAuth Login)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google Cloud OAuth Client Credentials (for OAuth Login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Nodemailer Email Verification SMTP Credentials
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_SECURE="false"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-specific-password"
EMAIL_FROM='"ZachCourse" <noreply@zachcourse.com>'

# Gemini API Key (Required for Personalized Course Material Generation)
GEMINI_API_KEY="your-gemini-api-key"
APP_URL="http://localhost:3000"
VITE_APP_URL="http://localhost:3000"

# Discord OAuth Credentials (for Verified Social Profile Badge)
# Needs a Discord Developer Portal application with Redirect URI: {BASE_URL}/api/auth/callback/discord
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

